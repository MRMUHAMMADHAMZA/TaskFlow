<Window x:Class="TaskManagementApp.Views.ActivityLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskFlow — Activity Log"
        Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowState="Maximized"
        Background="#0F0E17">

    <Window.Resources>

        <!-- SIDEBAR BUTTON -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A7A9BE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10" Margin="8,2">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="16,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg"
                                        Property="Background" Value="#1E1E3F"/>
                                <Setter Property="Foreground" Value="#FFFFFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ACTIVE SIDEBAR BUTTON -->
        <Style x:Key="SidebarButtonActive" TargetType="Button"
               BasedOn="{StaticResource SidebarButton}">
            <Setter Property="Background" Value="#1E1E3F"/>
            <Setter Property="Foreground" Value="#6C63FF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- FILTER COMBO -->
        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <ContentPresenter
                                        IsHitTestVisible="False"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        Margin="12,0,30,0"
                                        VerticalAlignment="Center"/>
                                    <TextBlock Text="▾"
                                               Foreground="#A7A9BE"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False">
                                <Border Background="#1E1E3F"
                                        BorderBrush="#6C63FF"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border"
                                        Property="BorderBrush" Value="#6C63FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A5A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#6C63FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ SIDEBAR ══ -->
        <Border Grid.Column="0" Background="#0A0A14"
                BorderBrush="#1A1A2E" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo & User -->
                <StackPanel Grid.Row="0" Margin="0,24,0,20">
                    <StackPanel Orientation="Horizontal"
                                Margin="24,0,0,20">
                        <Border Background="#6C63FF" CornerRadius="10"
                                Width="36" Height="36" Margin="0,0,10,0">
                            <TextBlock Text="✓" FontSize="18"
                                       FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="TaskFlow" FontSize="18"
                                   FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Background="#16213E" CornerRadius="12"
                            Margin="12,0" Padding="12,10">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#6C63FF" CornerRadius="50"
                                    Width="36" Height="36" Margin="0,0,10,0">
                                <TextBlock x:Name="txtAvatarInitial"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="txtSidebarName"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock x:Name="txtSidebarRole"
                                           FontSize="11" Foreground="#6C63FF"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Nav -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <TextBlock Text="MENU" Foreground="#3A3A5C"
                               FontSize="10" FontWeight="Bold"
                               Margin="24,0,0,8"/>

                    <Button Style="{StaticResource SidebarButton}"
                            Click="btnNavDashboard_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButton}"
                            Click="btnNavProjects_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Projects" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButton}"
                            Click="btnNavTasks_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✅" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Tasks" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButtonActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Activity Log" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Logout -->
                <StackPanel Grid.Row="2" Margin="0,0,0,20">
                    <Separator Background="#1A1A2E" Margin="16,0,16,12"/>
                    <Button Style="{StaticResource SidebarButton}"
                            Click="btnLogout_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Logout" Foreground="#FF6584"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ MAIN CONTENT ══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#0F0E17"
                    Padding="32,24,32,16">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Activity Log"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock x:Name="txtLogCount"
                                   FontSize="13" Foreground="#A7A9BE"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Clear Logs Button -->
                    <Button Content="🗑  Clear All Logs"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Height="40" Padding="20,0"
                            FontSize="13" FontWeight="SemiBold"
                            Foreground="#FF6584"
                            Background="#2A1020"
                            BorderThickness="0" Cursor="Hand"
                            Click="btnClearLogs_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg"
                                                Property="Background" Value="#3A1530"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Filter Bar -->
            <Border Grid.Row="1" Background="#0F0E17"
                    Padding="32,0,32,16">
                <StackPanel Orientation="Horizontal">

                    <!-- Filter by User -->
                    <ComboBox x:Name="cmbFilterUser"
                              Style="{StaticResource FilterCombo}"
                              Width="180" Margin="0,0,12,0"
                              SelectionChanged="Filter_Changed"/>

                    <!-- Filter by Date -->
                    <ComboBox x:Name="cmbFilterDate"
                              Style="{StaticResource FilterCombo}"
                              Width="160" Margin="0,0,12,0"
                              SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="All Time" IsSelected="True"/>
                        <ComboBoxItem Content="Today"/>
                        <ComboBoxItem Content="Last 7 Days"/>
                        <ComboBoxItem Content="Last 30 Days"/>
                    </ComboBox>

                    <!-- Refresh Button -->
                    <!-- Refresh Button -->
                    <Button x:Name="btnRefresh"
        Height="38" Padding="16,0"
        FontSize="13" Foreground="#A7A9BE"
        Background="#16213E"
        BorderThickness="0" Cursor="Hand"
        Click="btnRefresh_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg"
                    Background="{TemplateBinding Background}"
                    CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg"
                            Property="Background" Value="#1E1E3F"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="iconRefresh"
                   Text="⟳"
                   FontSize="16"
                   Foreground="#A7A9BE"
                   Margin="0,0,8,0"
                   VerticalAlignment="Center">
                                <TextBlock.RenderTransform>
                                    <RotateTransform x:Name="rotateTransform"
                                 CenterX="8" CenterY="8"/>
                                </TextBlock.RenderTransform>
                                <TextBlock.Triggers>
                                    <EventTrigger RoutedEvent="TextBlock.Loaded">
                                        <BeginStoryboard x:Name="spinStoryboard">
                                            <Storyboard x:Name="spinAnimation">
                                                <DoubleAnimation
                                Storyboard.TargetName="rotateTransform"
                                Storyboard.TargetProperty="Angle"
                                From="0" To="360"
                                Duration="0:0:0.8"
                                RepeatBehavior="1x"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </TextBlock.Triggers>
                            </TextBlock>
                            <TextBlock Text="Refresh"
                   FontSize="13"
                   Foreground="#A7A9BE"
                   VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Border>

            <!-- Logs List -->
            <Grid Grid.Row="2" Margin="32,0,32,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Border x:Name="tableHeader"
                        Grid.Row="0"
                        Background="#16213E"
                        CornerRadius="10"
                        Padding="20,10"
                        Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#"
                                   Foreground="#3A3A5C" FontSize="11"
                                   FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="USER"
                                   Foreground="#3A3A5C" FontSize="11"
                                   FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="ACTION"
                                   Foreground="#3A3A5C" FontSize="11"
                                   FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="TIME"
                                   Foreground="#3A3A5C" FontSize="11"
                                   FontWeight="Bold"/>
                    </Grid>
                </Border>

                <!-- Scrollable Rows -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Empty State -->
                        <Border x:Name="emptyState"
                                Visibility="Collapsed"
                                Padding="0,60">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="📋" FontSize="48"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="No activity yet"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,6"/>
                                <TextBlock Text="Actions like login, creating tasks and projects will appear here"
                                           FontSize="13" Foreground="#A7A9BE"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Log Rows -->
                        <ItemsControl x:Name="lstLogs">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#16213E"
                                            CornerRadius="10"
                                            Padding="20,12"
                                            Margin="0,0,0,4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                             Value="True">
                                                        <Setter Property="Background"
                                                                Value="#1E2A4E"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="140"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Row Number -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding RowNumber}"
                                                       FontSize="12"
                                                       Foreground="#3A3A5C"
                                                       VerticalAlignment="Center"/>

                                            <!-- User -->
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Border Background="#6C63FF"
                                                        CornerRadius="50"
                                                        Width="28" Height="28"
                                                        Margin="0,0,8,0">
                                                    <TextBlock
                                                        Text="{Binding UserInitial}"
                                                        FontSize="12"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock
                                                    Text="{Binding UserName}"
                                                    FontSize="12"
                                                    Foreground="White"
                                                    VerticalAlignment="Center"
                                                    TextTrimming="CharacterEllipsis"
                                                    MaxWidth="110"/>
                                            </StackPanel>

                                            <!-- Action -->
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Border Background="{Binding ActionColor}"
                                                        CornerRadius="50"
                                                        Width="8" Height="8"
                                                        Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding Action}"
                                                           FontSize="12"
                                                           Foreground="White"
                                                           TextWrapping="Wrap"
                                                           MaxWidth="400"/>
                                            </StackPanel>

                                            <!-- Time -->
                                            <StackPanel Grid.Column="3"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TimeAgo}"
                                                           FontSize="12"
                                                           Foreground="#A7A9BE"/>
                                                <TextBlock Text="{Binding FullDate}"
                                                           FontSize="10"
                                                           Foreground="#3A3A5C"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Grid>
</Window>