<Window x:Class="TaskManagementApp.Views.TaskDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Detail"
        Height="650" Width="700"
        MinHeight="500" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="#0F0E17"
        ResizeMode="CanResize">

    <Window.Resources>

        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A7A9BE"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="#1A1A2E" Padding="28,20">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="txtTaskTitle"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White"
                               TextWrapping="Wrap"
                               MaxWidth="500"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Border x:Name="borderPriority"
                                CornerRadius="20" Padding="10,3"
                                Margin="0,0,8,0">
                            <TextBlock x:Name="txtPriority"
                                       FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                        <Border x:Name="borderStatus"
                                CornerRadius="20" Padding="10,3">
                            <TextBlock x:Name="txtStatus"
                                       FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Close Button -->
                <Button Content="✕"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Width="32" Height="32"
                        FontSize="14"
                        Foreground="#A7A9BE"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="btnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg"
                                            Property="Background" Value="#2A2A4A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ── Task Details ── -->
        <Border Grid.Row="1" Padding="28,16,28,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left column -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="PROJECT" Style="{StaticResource DetailLabel}"/>
                    <TextBlock x:Name="txtProject"
                               Style="{StaticResource DetailValue}"/>

                    <TextBlock Text="ASSIGNED TO"
                               Style="{StaticResource DetailLabel}"/>
                    <TextBlock x:Name="txtAssignedTo"
                               Style="{StaticResource DetailValue}"/>
                </StackPanel>

                <!-- Right column -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="DUE DATE" Style="{StaticResource DetailLabel}"/>
                    <TextBlock x:Name="txtDueDate"
                               Style="{StaticResource DetailValue}"/>

                    <TextBlock Text="CREATED" Style="{StaticResource DetailLabel}"/>
                    <TextBlock x:Name="txtCreated"
                               Style="{StaticResource DetailValue}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Description + Comments ── -->
        <Grid Grid.Row="2" Margin="28,0,28,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Description -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="DESCRIPTION"
                           Style="{StaticResource DetailLabel}"/>
                <Border Background="#16213E" CornerRadius="8" Padding="12">
                    <TextBlock x:Name="txtDescription"
                               Foreground="White" FontSize="13"
                               TextWrapping="Wrap"
                               LineHeight="20"/>
                </Border>
            </StackPanel>

            <!-- Comments Header -->
            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                <Grid>
                    <TextBlock Text="COMMENTS"
                               Style="{StaticResource DetailLabel}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtCommentCount"
                               Foreground="#6C63FF"
                               FontSize="11" FontWeight="SemiBold"
                               HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>

            <!-- Comments List -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Empty comments -->
                    <Border x:Name="emptyComments"
                            Visibility="Collapsed"
                            Padding="0,20">
                        <TextBlock Text="No comments yet. Be the first to comment!"
                                   Foreground="#A7A9BE" FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Comments -->
                    <ItemsControl x:Name="lstComments">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#16213E"
                                        CornerRadius="10"
                                        Padding="14,10"
                                        Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Top: avatar + name + time + delete -->
                                        <Grid Grid.Row="0" Margin="0,0,0,6">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="#6C63FF"
                                                        CornerRadius="50"
                                                        Width="26" Height="26"
                                                        Margin="0,0,8,0">
                                                    <TextBlock
                                                        Text="{Binding UserInitial}"
                                                        FontSize="11"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock
                                                    Text="{Binding UserName}"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Foreground="White"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,10,0"/>
                                                <TextBlock
                                                    Text="{Binding TimeAgo}"
                                                    FontSize="11"
                                                    Foreground="#A7A9BE"
                                                    VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Delete -->
                                            <Button Content="✕"
                                                    HorizontalAlignment="Right"
                                                    Tag="{Binding CommentID}"
                                                    Width="22" Height="22"
                                                    FontSize="10"
                                                    Foreground="#FF6584"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Click="btnDeleteComment_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bg"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="4">
                                                            <ContentPresenter
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver"
                                                                     Value="True">
                                                                <Setter TargetName="bg"
                                                                        Property="Background"
                                                                        Value="#2A1020"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>

                                        <!-- Comment text -->
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Content}"
                                                   FontSize="13"
                                                   Foreground="#FFFFFE"
                                                   TextWrapping="Wrap"
                                                   LineHeight="20"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ── Add Comment Box ── -->
        <Border Grid.Row="3"
                Background="#1A1A2E"
                Padding="28,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#16213E"
                        BorderBrush="#2A2A4A"
                        BorderThickness="1"
                        CornerRadius="10"
                        Margin="0,0,10,0">
                    <TextBox x:Name="txtNewComment"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             FontSize="13"
                             Padding="12,10"
                             TextWrapping="Wrap"
                             MaxHeight="80"
                             VerticalScrollBarVisibility="Auto"
                             CaretBrush="White"
                             SelectionBrush="#6C63FF">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush AlignmentX="Left"
                                                             AlignmentY="Center"
                                                             Stretch="None">
                                                    <VisualBrush.Visual>
                                                        <TextBlock
                                                            Text="Write a comment..."
                                                            Foreground="#3A3A5C"
                                                            FontSize="13"
                                                            Margin="12,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>

                <Button x:Name="btnAddComment"
                        Grid.Column="1"
                        Content="Post"
                        Width="70" Height="42"
                        FontSize="13" FontWeight="SemiBold"
                        Foreground="White"
                        Background="#6C63FF"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="btnAddComment_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg"
                                            Property="Background" Value="#5A52E0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>
        </Border>

    </Grid>
</Window>