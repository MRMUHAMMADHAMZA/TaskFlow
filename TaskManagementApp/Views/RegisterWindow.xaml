<Window x:Class="TaskManagementApp.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskFlow — Register"
        Height="680" Width="900"
        WindowState="Maximized"
        ResizeMode="CanResize"
        MinHeight="600" MinWidth="700"
        Background="#0F0E17">

    <Window.Resources>
        <!-- Input Field Style -->
        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1E1E3F"/>
            <Setter Property="CaretBrush" Value="#6C63FF"/>
            <Setter Property="SelectionBrush" Value="#6C63FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6C63FF"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4A4A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Password Field Style -->
        <Style x:Key="PasswordField" TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1E1E3F"/>
            <Setter Property="CaretBrush" Value="#6C63FF"/>
            <Setter Property="SelectionBrush" Value="#6C63FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
            <Setter Property="Padding" Value="12,0,45,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6C63FF"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4A4A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Eye Button Style -->
        <Style x:Key="EyeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label Style -->
        <Style x:Key="FieldLbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A7A9BE"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Error Style -->
        <Style x:Key="ErrText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF6584"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="2,4,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1.3*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ LEFT PANEL ══ -->
        <Border Grid.Column="0" Background="#16213E">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="35">

                <!-- Logo -->
                <Border Background="#6C63FF" CornerRadius="18"
                        Width="70" Height="70"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,22">
                    <Border.Effect>
                        <DropShadowEffect Color="#6C63FF" BlurRadius="20"
                                          ShadowDepth="0" Opacity="0.6"/>
                    </Border.Effect>
                    <TextBlock Text="🚀" FontSize="32"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Join TaskFlow"
                           FontSize="30" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Create your free account and&#10;start managing projects like a pro."
                           FontSize="13" Foreground="#A7A9BE"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           LineHeight="22"
                           Margin="0,0,0,35"/>

                <!-- Feature list -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Background="#2A2A6A" CornerRadius="50"
                                Width="28" Height="28" Margin="0,0,12,0">
                            <TextBlock Text="✓" FontSize="13" FontWeight="Bold"
                                       Foreground="#6C63FF"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Track unlimited projects"
                                   Foreground="#CDD0E3" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Background="#2A2A6A" CornerRadius="50"
                                Width="28" Height="28" Margin="0,0,12,0">
                            <TextBlock Text="✓" FontSize="13" FontWeight="Bold"
                                       Foreground="#6C63FF"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Collaborate with your team"
                                   Foreground="#CDD0E3" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#2A2A6A" CornerRadius="50"
                                Width="28" Height="28" Margin="0,0,12,0">
                            <TextBlock Text="✓" FontSize="13" FontWeight="Bold"
                                       Foreground="#6C63FF"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Real-time progress reports"
                                   Foreground="#CDD0E3" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Stats -->
                <Grid Margin="0,35,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#1E2D5A"
                            CornerRadius="10" Padding="15,12"
                            Margin="0,0,5,0">
                        <StackPanel>
                            <TextBlock Text="∞" FontSize="22"
                                       Foreground="#6C63FF"
                                       HorizontalAlignment="Center"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Projects"
                                       Foreground="#A7A9BE" FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#1E2D5A"
                            CornerRadius="10" Padding="15,12"
                            Margin="5,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Free" FontSize="18"
                                       Foreground="#2CB67D"
                                       HorizontalAlignment="Center"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Forever"
                                       Foreground="#A7A9BE" FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </Border>

        <!-- ══ RIGHT PANEL ══ -->
        <Border Grid.Column="1" Background="#0F0E17">
            <ScrollViewer VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly">
                <StackPanel Margin="50,35,50,30">

                    <TextBlock Text="Create account"
                               FontSize="26" FontWeight="Bold"
                               Foreground="White" Margin="0,0,0,4"/>
                    <TextBlock Text="Fill in the details below to get started"
                               FontSize="13" Foreground="#A7A9BE"
                               Margin="0,0,0,28"/>

                    <!-- ── Full Name ── -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="FULL NAME" Style="{StaticResource FieldLbl}"/>
                        <TextBox x:Name="txtFullName"
                                 Style="{StaticResource InputField}"
                                 TextChanged="txtFullName_TextChanged"/>
                        <TextBlock x:Name="errFullName"
                                   Style="{StaticResource ErrText}"/>
                    </StackPanel>

                    <!-- ── Email ── -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="EMAIL ADDRESS" Style="{StaticResource FieldLbl}"/>
                        <TextBox x:Name="txtEmail"
                                 Style="{StaticResource InputField}"
                                 TextChanged="txtEmail_TextChanged"/>
                        <TextBlock x:Name="errEmail"
                                   Style="{StaticResource ErrText}"/>
                    </StackPanel>

                    <!-- ── Role ── -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="ROLE" Style="{StaticResource FieldLbl}"/>
                        <ComboBox x:Name="cmbRole"
                                  Height="42"
                                  FontSize="13"
                                  Foreground="White"
                                  Background="#1E1E3F"
                                  BorderBrush="#2A2A4A"
                                  BorderThickness="1"
                                  Cursor="Hand"
                                  Style="{StaticResource ModernComboBox}">
                            <ComboBoxItem Content="User" IsSelected="True"/>
                            <ComboBoxItem Content="Admin"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- ── Password ── -->
                    <StackPanel Margin="0,0,0,6">
                        <TextBlock Text="PASSWORD" Style="{StaticResource FieldLbl}"/>
                        <Grid>
                            <PasswordBox x:Name="txtPassword"
                                         Style="{StaticResource PasswordField}"
                                         PasswordChanged="txtPassword_PasswordChanged"/>
                            <TextBox x:Name="txtPasswordVisible"
                                     Style="{StaticResource InputField}"
                                     Padding="12,0,45,0"
                                     Visibility="Collapsed"/>
                            <Button x:Name="btnTogglePassword"
                                    Style="{StaticResource EyeButton}"
                                    Content="👁"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,0"
                                    Click="btnTogglePassword_Click"/>
                        </Grid>
                        <TextBlock x:Name="errPassword"
                                   Style="{StaticResource ErrText}"/>

                        <!-- Strength Bar -->
                        <Grid x:Name="strengthBar"
                              Margin="0,8,0,0"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="s1" Grid.Column="0" Height="4"
                                    CornerRadius="2" Background="#2A2A4A"
                                    Margin="0,0,3,0"/>
                            <Border x:Name="s2" Grid.Column="1" Height="4"
                                    CornerRadius="2" Background="#2A2A4A"
                                    Margin="0,0,3,0"/>
                            <Border x:Name="s3" Grid.Column="2" Height="4"
                                    CornerRadius="2" Background="#2A2A4A"
                                    Margin="0,0,3,0"/>
                            <Border x:Name="s4" Grid.Column="3" Height="4"
                                    CornerRadius="2" Background="#2A2A4A"/>
                        </Grid>
                        <TextBlock x:Name="txtStrength"
                                   FontSize="11" Foreground="#A7A9BE"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- ── Confirm Password ── -->
                    <StackPanel Margin="0,10,0,16">
                        <TextBlock Text="CONFIRM PASSWORD"
                                   Style="{StaticResource FieldLbl}"/>
                        <Grid>
                            <PasswordBox x:Name="txtConfirmPassword"
                                         Style="{StaticResource PasswordField}"
                                         PasswordChanged="txtConfirm_PasswordChanged"/>
                            <TextBox x:Name="txtConfirmVisible"
                                     Style="{StaticResource InputField}"
                                     Padding="12,0,45,0"
                                     Visibility="Collapsed"/>
                            <Button x:Name="btnToggleConfirm"
                                    Style="{StaticResource EyeButton}"
                                    Content="👁"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,0"
                                    Click="btnToggleConfirm_Click"/>
                        </Grid>
                        <TextBlock x:Name="errConfirmPassword"
                                   Style="{StaticResource ErrText}"/>
                    </StackPanel>

                    <!-- ── General Error ── -->
                    <Border x:Name="borderError"
                            Background="#2A1020"
                            BorderBrush="#FF6584"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,10"
                            Margin="0,0,0,10"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠  " Foreground="#FF6584" FontSize="13"/>
                            <TextBlock x:Name="txtError"
                                       Foreground="#FF6584"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Success ── -->
                    <Border x:Name="borderSuccess"
                            Background="#0A2A1A"
                            BorderBrush="#2CB67D"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,10"
                            Margin="0,0,0,10"
                            Visibility="Collapsed">
                        <TextBlock Text="✓  Account created! Redirecting to login..."
                                   Foreground="#2CB67D" FontSize="13"/>
                    </Border>

                    <!-- ── Register Button ── -->
                    <Button x:Name="btnRegister"
                            Content="Create Account"
                            Height="46"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Background="#6C63FF"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,4,0,0"
                            Click="btnRegister_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder"
                                                Property="Background" Value="#5A52E0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="btnBorder"
                                                Property="Background" Value="#4A42D0"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="btnBorder"
                                                Property="Background" Value="#3A3A5C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- ── Login Link ── -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,18,0,10">
                        <TextBlock Text="Already have an account?  "
                                   Foreground="#A7A9BE" FontSize="13"/>
                        <TextBlock Text="Sign in"
                                   Foreground="#6C63FF"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Cursor="Hand"
                                   MouseLeftButtonDown="Login_Click">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>