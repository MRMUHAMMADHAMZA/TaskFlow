<Window x:Class="TaskManagementApp.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskFlow — Dashboard"
        Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowState="Maximized"
        Background="#0F0E17">

    <Window.Resources>

        <!-- SIDEBAR BUTTON STYLE -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A7A9BE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Margin="8,2">
                            <ContentPresenter
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="16,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg"
                                        Property="Background"
                                        Value="#1E1E3F"/>
                                <Setter Property="Foreground" Value="#FFFFFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ACTIVE SIDEBAR BUTTON -->
        <Style x:Key="SidebarButtonActive" TargetType="Button"
               BasedOn="{StaticResource SidebarButton}">
            <Setter Property="Background" Value="#1E1E3F"/>
            <Setter Property="Foreground" Value="#6C63FF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- STAT CARD STYLE -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="22,18"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="220"/>
            <!-- Main Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════
             SIDEBAR
        ══════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="#0A0A14"
                BorderBrush="#1A1A2E"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo & User -->
                <StackPanel Grid.Row="0" Margin="0,24,0,20">

                    <!-- Logo -->
                    <StackPanel Orientation="Horizontal"
                                Margin="24,0,0,20">
                        <Border Background="#6C63FF"
                                CornerRadius="10"
                                Width="36" Height="36"
                                Margin="0,0,10,0">
                            <TextBlock Text="✓"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="TaskFlow"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- User Card -->
                    <Border Background="#16213E"
                            CornerRadius="12"
                            Margin="12,0"
                            Padding="12,10">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#6C63FF"
                                    CornerRadius="50"
                                    Width="36" Height="36"
                                    Margin="0,0,10,0">
                                <TextBlock x:Name="txtAvatarInitial"
                                           Text="J"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="txtSidebarName"
                                           Text="John Doe"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock x:Name="txtSidebarRole"
                                           Text="Admin"
                                           FontSize="11"
                                           Foreground="#6C63FF"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">

                    <TextBlock Text="MENU"
                               Foreground="#3A3A5C"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="24,0,0,8"/>

                    <Button x:Name="btnNavDashboard"
                            Style="{StaticResource SidebarButtonActive}"
                            Click="btnNavDashboard_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="14"
                                       Margin="0,0,10,0"/>
                            <TextBlock Text="Dashboard"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnNavProjects"
                            Style="{StaticResource SidebarButton}"
                            Click="btnNavProjects_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁" FontSize="14"
                                       Margin="0,0,10,0"/>
                            <TextBlock Text="Projects"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnNavTasks"
                            Style="{StaticResource SidebarButton}"
                            Click="btnNavTasks_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✅" FontSize="14"
                                       Margin="0,0,10,0"/>
                            <TextBlock Text="Tasks"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnNavActivity"
                            Style="{StaticResource SidebarButton}"
                            Click="btnNavActivity_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="14"
                                       Margin="0,0,10,0"/>
                            <TextBlock Text="Activity Log"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Logout -->
                <StackPanel Grid.Row="2" Margin="0,0,0,20">
                    <Separator Background="#1A1A2E" Margin="16,0,16,12"/>
                    <Button Style="{StaticResource SidebarButton}"
                            Click="btnLogout_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪" FontSize="14"
                                       Margin="0,0,10,0"/>
                            <TextBlock Text="Logout"
                                       Foreground="#FF6584"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ══════════════════════════════════════
             MAIN CONTENT
        ══════════════════════════════════════ -->
        <Grid Grid.Column="1" Background="#0F0E17">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="32,28,32,32">

                    <!-- ── Top Header ── -->
                    <Grid Margin="0,0,0,28">
                        <StackPanel>
                            <TextBlock x:Name="txtGreeting"
                                       Text="Good morning, John 👋"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock x:Name="txtDate"
                                       Foreground="#A7A9BE"
                                       FontSize="13"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Refresh Button -->
                        <!-- Refresh Button -->
                        <Button HorizontalAlignment="Right"
        VerticalAlignment="Center"
        Height="36" Padding="16,0"
        Foreground="#A7A9BE"
        Background="#16213E"
        BorderThickness="0"
        Cursor="Hand"
        Click="btnRefresh_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg"
                    Background="{TemplateBinding Background}"
                    CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg"
                            Property="Background" Value="#1E1E3F"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="iconRefresh"
                   Text="⟳"
                   FontSize="16"
                   Foreground="#A7A9BE"
                   Margin="0,0,8,0"
                   VerticalAlignment="Center">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="rotateTransform"
                                 CenterX="8" CenterY="8"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <TextBlock Text="Refresh"
                   FontSize="13"
                   Foreground="#A7A9BE"
                   VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- ── Stats Cards ── -->
                    <TextBlock Text="OVERVIEW"
                               Foreground="#3A3A5C"
                               FontSize="11"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Total Projects -->
                        <Border Grid.Column="0"
                                Style="{StaticResource StatCard}"
                                Margin="0,0,10,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,14">
                                    <Border Background="#1A1A5E"
                                            CornerRadius="8"
                                            Width="36" Height="36">
                                        <TextBlock Text="📁"
                                                   FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="txtTotalProjects"
                                           Text="0"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock Text="Total Projects"
                                           FontSize="12"
                                           Foreground="#A7A9BE"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Total Tasks -->
                        <Border Grid.Column="1"
                                Style="{StaticResource StatCard}"
                                Margin="5,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,14">
                                    <Border Background="#1A3A2E"
                                            CornerRadius="8"
                                            Width="36" Height="36">
                                        <TextBlock Text="✅"
                                                   FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="txtTotalTasks"
                                           Text="0"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock Text="Total Tasks"
                                           FontSize="12"
                                           Foreground="#A7A9BE"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- In Progress -->
                        <Border Grid.Column="2"
                                Style="{StaticResource StatCard}"
                                Margin="5,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,14">
                                    <Border Background="#2A1A00"
                                            CornerRadius="8"
                                            Width="36" Height="36">
                                        <TextBlock Text="⏳"
                                                   FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="txtInProgress"
                                           Text="0"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="#FFD166"/>
                                <TextBlock Text="In Progress"
                                           FontSize="12"
                                           Foreground="#A7A9BE"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Completed -->
                        <Border Grid.Column="3"
                                Style="{StaticResource StatCard}"
                                Margin="10,0,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,14">
                                    <Border Background="#0A2A1A"
                                            CornerRadius="8"
                                            Width="36" Height="36">
                                        <TextBlock Text="🏆"
                                                   FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="txtCompleted"
                                           Text="0"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="#2CB67D"/>
                                <TextBlock Text="Completed"
                                           FontSize="12"
                                           Foreground="#A7A9BE"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                    </Grid>

                    <!-- ── Bottom Two Columns ── -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <!-- Recent Tasks -->
                        <Border Grid.Column="0"
                                Background="#16213E"
                                CornerRadius="16"
                                Padding="22"
                                Margin="0,0,16,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <TextBlock Text="Recent Tasks"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>
                                    <Button Content="+ New Task"
                                            HorizontalAlignment="Right"
                                            Height="30"
                                            Padding="12,0"
                                            FontSize="12"
                                            Foreground="White"
                                            Background="#6C63FF"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="btnNewTask_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="8">
                                                    <ContentPresenter
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                             Value="True">
                                                        <Setter TargetName="bg"
                                                                Property="Background"
                                                                Value="#5A52E0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <!-- Tasks List -->
                                <ItemsControl x:Name="lstRecentTasks">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0F0E17"
                                                    CornerRadius="10"
                                                    Padding="14,12"
                                                    Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White"/>
                                                        <TextBlock Text="{Binding ProjectName}"
                                                                   FontSize="11"
                                                                   Foreground="#A7A9BE"
                                                                   Margin="0,3,0,0"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="1"
                                                            Background="{Binding StatusColor}"
                                                            CornerRadius="6"
                                                            Padding="8,3"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Status}"
                                                                   FontSize="10"
                                                                   Foreground="White"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty State -->
                                <Border x:Name="emptyTasks"
                                        Visibility="Collapsed"
                                        Padding="0,20">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="📭"
                                                   FontSize="32"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="No tasks yet"
                                                   FontSize="13"
                                                   Foreground="#A7A9BE"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Border>

                        <!-- Recent Activity -->
                        <Border Grid.Column="1"
                                Background="#16213E"
                                CornerRadius="16"
                                Padding="22">
                            <StackPanel>
                                <TextBlock Text="Recent Activity"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           Margin="0,0,0,16"/>

                                <ItemsControl x:Name="lstActivity">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,0,0,14">
                                                <!-- Timeline dot -->
                                                <Border Background="#6C63FF"
                                                        CornerRadius="50"
                                                        Width="8" Height="8"
                                                        VerticalAlignment="Top"
                                                        Margin="0,4,12,0"/>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Action}"
                                                               FontSize="12"
                                                               Foreground="White"
                                                               TextWrapping="Wrap"
                                                               MaxWidth="220"/>
                                                    <TextBlock Text="{Binding TimeAgo}"
                                                               FontSize="10"
                                                               Foreground="#3A3A5C"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty State -->
                                <Border x:Name="emptyActivity"
                                        Visibility="Collapsed"
                                        Padding="0,20">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="📭"
                                                   FontSize="28"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="No activity yet"
                                                   FontSize="12"
                                                   Foreground="#A7A9BE"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Border>

                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Grid>

    </Grid>
</Window>