<Window x:Class="TaskManagementApp.Views.TasksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskFlow — Tasks"
        Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowState="Maximized"
        Background="#0F0E17">

    <Window.Resources>

        <!-- SIDEBAR BUTTON -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A7A9BE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10" Margin="8,2">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="16,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg"
                                        Property="Background" Value="#1E1E3F"/>
                                <Setter Property="Foreground" Value="#FFFFFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ACTIVE SIDEBAR BUTTON -->
        <Style x:Key="SidebarButtonActive" TargetType="Button"
               BasedOn="{StaticResource SidebarButton}">
            <Setter Property="Background" Value="#1E1E3F"/>
            <Setter Property="Foreground" Value="#6C63FF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- FORM INPUT -->
        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1E1E3F"/>
            <Setter Property="CaretBrush" Value="#6C63FF"/>
            <Setter Property="SelectionBrush" Value="#6C63FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border"
                                        Property="BorderBrush" Value="#6C63FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- FORM TEXTAREA -->
        <Style x:Key="FormTextArea" TargetType="TextBox"
               BasedOn="{StaticResource FormInput}">
            <Setter Property="Height" Value="80"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="AcceptsReturn" Value="True"/>
        </Style>

        <!-- COMBO BOX -->
        <Style x:Key="FormCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1E1E3F"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <ContentPresenter
                                        x:Name="ContentSite"
                                        IsHitTestVisible="False"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        Margin="12,0,30,0"
                                        VerticalAlignment="Center"/>
                                    <TextBlock Text="▾"
                                               Foreground="#A7A9BE"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#1E1E3F"
                                        BorderBrush="#6C63FF"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border"
                                        Property="BorderBrush" Value="#6C63FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A5A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#6C63FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ SIDEBAR ══ -->
        <Border Grid.Column="0" Background="#0A0A14"
                BorderBrush="#1A1A2E" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo & User -->
                <StackPanel Grid.Row="0" Margin="0,24,0,20">
                    <StackPanel Orientation="Horizontal"
                                Margin="24,0,0,20">
                        <Border Background="#6C63FF" CornerRadius="10"
                                Width="36" Height="36" Margin="0,0,10,0">
                            <TextBlock Text="✓" FontSize="18"
                                       FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="TaskFlow" FontSize="18"
                                   FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Background="#16213E" CornerRadius="12"
                            Margin="12,0" Padding="12,10">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#6C63FF" CornerRadius="50"
                                    Width="36" Height="36" Margin="0,0,10,0">
                                <TextBlock x:Name="txtAvatarInitial"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="txtSidebarName"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock x:Name="txtSidebarRole"
                                           FontSize="11" Foreground="#6C63FF"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Nav -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <TextBlock Text="MENU" Foreground="#3A3A5C"
                               FontSize="10" FontWeight="Bold"
                               Margin="24,0,0,8"/>

                    <Button Style="{StaticResource SidebarButton}"
                            Click="btnNavDashboard_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButton}"
                            Click="btnNavProjects_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Projects" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButtonActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✅" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Tasks" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnNavActivity"
        Style="{StaticResource SidebarButton}"
        Click="btnNavActivity_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Activity Log" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Logout -->
                <StackPanel Grid.Row="2" Margin="0,0,0,20">
                    <Separator Background="#1A1A2E" Margin="16,0,16,12"/>
                    <Button Style="{StaticResource SidebarButton}"
                            Click="btnLogout_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Logout" Foreground="#FF6584"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ MAIN CONTENT ══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#0F0E17"
                    Padding="32,24,32,16">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Tasks" FontSize="22"
                                   FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="txtTaskCount"
                                   FontSize="13" Foreground="#A7A9BE"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="+ New Task"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Height="40" Padding="20,0"
                            FontSize="13" FontWeight="SemiBold"
                            Foreground="White" Background="#6C63FF"
                            BorderThickness="0" Cursor="Hand"
                            Click="btnNewTask_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg"
                                                Property="Background" Value="#5A52E0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Filter Bar -->
            <Border Grid.Row="1" Background="#0F0E17"
                    Padding="32,0,32,16">
                <StackPanel Orientation="Horizontal">

                    <ComboBox x:Name="cmbFilterStatus"
                              Style="{StaticResource FormCombo}"
                              Width="150" Margin="0,0,12,0"
                              SelectionChanged="cmbFilterStatus_SelectionChanged">
                        <ComboBoxItem Content="All Status" IsSelected="True"/>
                        <ComboBoxItem Content="To Do"/>
                        <ComboBoxItem Content="In Progress"/>
                        <ComboBoxItem Content="Done"/>
                    </ComboBox>

                    <ComboBox x:Name="cmbFilterPriority"
                              Style="{StaticResource FormCombo}"
                              Width="150" Margin="0,0,12,0"
                              SelectionChanged="cmbFilterPriority_SelectionChanged">
                        <ComboBoxItem Content="All Priority" IsSelected="True"/>
                        <ComboBoxItem Content="Low"/>
                        <ComboBoxItem Content="Medium"/>
                        <ComboBoxItem Content="High"/>
                    </ComboBox>

                    <ComboBox x:Name="cmbFilterProject"
                              Style="{StaticResource FormCombo}"
                              Width="180"
                              SelectionChanged="cmbFilterProject_SelectionChanged"/>

                </StackPanel>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition x:Name="colForm" Width="0"/>
                </Grid.ColumnDefinitions>

                <!-- Tasks List -->
                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              Padding="32,0,32,32">
                    <StackPanel>

                        <!-- Empty State -->
                        <Border x:Name="emptyState"
                                Visibility="Collapsed" Padding="0,60">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="✅" FontSize="48"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="No tasks yet"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,6"/>
                                <TextBlock Text="Click '+ New Task' to create your first task"
                                           FontSize="13" Foreground="#A7A9BE"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Table Header -->
                        <Border x:Name="tableHeader"
                                Background="#16213E"
                                CornerRadius="10"
                                Padding="16,10"
                                Margin="0,8,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="TASK"
                                           Foreground="#3A3A5C" FontSize="11"
                                           FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="PROJECT"
                                           Foreground="#3A3A5C" FontSize="11"
                                           FontWeight="Bold"/>
                                <TextBlock Grid.Column="2" Text="PRIORITY"
                                           Foreground="#3A3A5C" FontSize="11"
                                           FontWeight="Bold"/>
                                <TextBlock Grid.Column="3" Text="STATUS"
                                           Foreground="#3A3A5C" FontSize="11"
                                           FontWeight="Bold"/>
                                <TextBlock Grid.Column="4" Text="DUE DATE"
                                           Foreground="#3A3A5C" FontSize="11"
                                           FontWeight="Bold"/>
                                <TextBlock Grid.Column="5" Text="ACTIONS"
                                           Foreground="#3A3A5C" FontSize="11"
                                           FontWeight="Bold"/>
                            </Grid>
                        </Border>

                        <!-- Task Rows -->
                        <ItemsControl x:Name="lstTasks">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#16213E"
                                            CornerRadius="10"
                                            Padding="16,12"
                                            Margin="0,0,0,4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                             Value="True">
                                                        <Setter Property="Background"
                                                                Value="#1E2A4E"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="150"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Title & Assigned -->
                                            <StackPanel Grid.Column="0"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding AssignedToName}"
                                                           FontSize="11"
                                                           Foreground="#A7A9BE"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Project -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ProjectName}"
                                                       FontSize="12"
                                                       Foreground="#A7A9BE"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <!-- Priority Badge -->
                                            <Border Grid.Column="2"
                                                    Background="{Binding PriorityColor}"
                                                    CornerRadius="6"
                                                    Padding="8,4"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Priority}"
                                                           FontSize="10"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"/>
                                            </Border>

                                            <!-- Status Badge -->
                                            <Border Grid.Column="3"
                                                    Background="{Binding StatusColor}"
                                                    CornerRadius="6"
                                                    Padding="8,4"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status}"
                                                           FontSize="10"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"/>
                                            </Border>

                                            <!-- Due Date -->
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding DueDate}"
                                                       FontSize="12"
                                                       Foreground="{Binding DueDateColor}"
                                                       VerticalAlignment="Center"/>

                                            <!-- Action Buttons -->
                                            <StackPanel Grid.Column="5"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">

                                                <!-- View -->
                                                <Button Content="👁"
                                                        Tag="{Binding TaskID}"
                                                        Width="30" Height="30"
                                                        FontSize="13"
                                                        Foreground="#2CB67D"
                                                        Background="#0A2A1A"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Margin="0,0,6,0"
                                                        Click="btnView_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bg"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="8">
                                                                <ContentPresenter
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bg"
                                                                            Property="Background"
                                                                            Value="#0F3A22"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <!-- Edit -->
                                                <Button Content="✏"
                                                        Tag="{Binding TaskID}"
                                                        Width="30" Height="30"
                                                        FontSize="13"
                                                        Foreground="#6C63FF"
                                                        Background="#1A1A5E"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Margin="0,0,6,0"
                                                        Click="btnEdit_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bg"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="8">
                                                                <ContentPresenter
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bg"
                                                                            Property="Background"
                                                                            Value="#252570"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <!-- Delete -->
                                                <Button Content="🗑"
                                                        Tag="{Binding TaskID}"
                                                        Width="30" Height="30"
                                                        FontSize="13"
                                                        Foreground="#FF6584"
                                                        Background="#2A1020"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Click="btnDelete_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bg"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="8">
                                                                <ContentPresenter
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bg"
                                                                            Property="Background"
                                                                            Value="#3A1530"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                            </StackPanel>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>

                <!-- ══ SLIDE-IN FORM ══ -->
                <Border x:Name="formPanel"
                        Grid.Column="1"
                        Background="#0A0A14"
                        BorderBrush="#1A1A2E"
                        BorderThickness="1,0,0,0"
                        Padding="28,24">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <TextBlock x:Name="txtFormTitle"
                                       Text="New Task"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,24"/>

                            <!-- Title -->
                            <TextBlock Text="TASK TITLE"
                                       Foreground="#A7A9BE" FontSize="11"
                                       FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBox x:Name="txtTitle"
                                     Style="{StaticResource FormInput}"
                                     Margin="0,0,0,4"/>
                            <TextBlock x:Name="errTitle"
                                       Foreground="#FF6584" FontSize="11"
                                       Visibility="Collapsed"
                                       Margin="0,0,0,8"/>

                            <!-- Description -->
                            <TextBlock Text="DESCRIPTION"
                                       Foreground="#A7A9BE" FontSize="11"
                                       FontWeight="Bold" Margin="0,12,0,6"/>
                            <TextBox x:Name="txtDescription"
                                     Style="{StaticResource FormTextArea}"
                                     Margin="0,0,0,12"/>

                            <!-- Project -->
                            <TextBlock Text="PROJECT"
                                       Foreground="#A7A9BE" FontSize="11"
                                       FontWeight="Bold" Margin="0,0,0,6"/>
                            <ComboBox x:Name="cmbProject"
                                      Style="{StaticResource FormCombo}"
                                      Margin="0,0,0,4"/>
                            <TextBlock x:Name="errProject"
                                       Foreground="#FF6584" FontSize="11"
                                       Visibility="Collapsed"
                                       Margin="0,0,0,8"/>

                            <!-- Assign To -->
                            <TextBlock Text="ASSIGN TO"
                                       Foreground="#A7A9BE" FontSize="11"
                                       FontWeight="Bold" Margin="0,12,0,6"/>
                            <ComboBox x:Name="cmbAssignTo"
                                      Style="{StaticResource FormCombo}"
                                      Margin="0,0,0,12"/>

                            <!-- Priority & Status -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="PRIORITY"
                                               Foreground="#A7A9BE" FontSize="11"
                                               FontWeight="Bold" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="cmbPriority"
                                              Style="{StaticResource FormCombo}">
                                        <ComboBoxItem Content="Low"/>
                                        <ComboBoxItem Content="Medium"
                                                      IsSelected="True"/>
                                        <ComboBoxItem Content="High"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="STATUS"
                                               Foreground="#A7A9BE" FontSize="11"
                                               FontWeight="Bold" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="cmbStatus"
                                              Style="{StaticResource FormCombo}">
                                        <ComboBoxItem Content="To Do"
                                                      IsSelected="True"/>
                                        <ComboBoxItem Content="In Progress"/>
                                        <ComboBoxItem Content="Done"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- Due Date -->
                            <TextBlock Text="DUE DATE (OPTIONAL)"
                                       Foreground="#A7A9BE" FontSize="11"
                                       FontWeight="Bold" Margin="0,0,0,6"/>
                            <DatePicker x:Name="dpDueDate"
                                        Height="40"
                                        FontSize="13"
                                        Foreground="White"
                                        Background="#1E1E3F"
                                        BorderBrush="#2A2A4A"
                                        BorderThickness="1"
                                        Margin="0,0,0,12"/>

                            <!-- Error Banner -->
                            <Border x:Name="borderError"
                                    Background="#2A1020"
                                    BorderBrush="#FF6584"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,8,0,0"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="txtError"
                                           Foreground="#FF6584"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <!-- Buttons -->
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,20,0,0">
                                <Button x:Name="btnSave"
                                        Content="Save Task"
                                        Height="40" Padding="20,0"
                                        FontSize="13" FontWeight="SemiBold"
                                        Foreground="White" Background="#6C63FF"
                                        BorderThickness="0" Cursor="Hand"
                                        Margin="0,0,10,0"
                                        Click="btnSave_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="10">
                                                <ContentPresenter
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg"
                                                            Property="Background"
                                                            Value="#5A52E0"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="bg"
                                                            Property="Background"
                                                            Value="#3A3A5C"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button Content="Cancel"
                                        Height="40" Padding="20,0"
                                        FontSize="13" Foreground="#A7A9BE"
                                        Background="#1E1E3F"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="btnCancel_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="10">
                                                <ContentPresenter
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg"
                                                            Property="Background"
                                                            Value="#2A2A5A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>