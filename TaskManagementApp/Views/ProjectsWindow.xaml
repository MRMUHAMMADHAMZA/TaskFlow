<Window x:Class="TaskManagementApp.Views.ProjectsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskFlow — Projects"
        Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowState="Maximized"
        Background="#0F0E17">

    <Window.Resources>

        <!-- SIDEBAR BUTTON -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A7A9BE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Margin="8,2">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="16,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg"
                                        Property="Background" Value="#1E1E3F"/>
                                <Setter Property="Foreground" Value="#FFFFFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ACTIVE SIDEBAR BUTTON -->
        <Style x:Key="SidebarButtonActive" TargetType="Button"
               BasedOn="{StaticResource SidebarButton}">
            <Setter Property="Background" Value="#1E1E3F"/>
            <Setter Property="Foreground" Value="#6C63FF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- INPUT FIELD -->
        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1E1E3F"/>
            <Setter Property="CaretBrush" Value="#6C63FF"/>
            <Setter Property="SelectionBrush" Value="#6C63FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border"
                                        Property="BorderBrush" Value="#6C63FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- MULTILINE INPUT -->
        <Style x:Key="FormTextArea" TargetType="TextBox"
               BasedOn="{StaticResource FormInput}">
            <Setter Property="Height" Value="80"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="AcceptsReturn" Value="True"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ SIDEBAR ══ -->
        <Border Grid.Column="0"
                Background="#0A0A14"
                BorderBrush="#1A1A2E"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo & User -->
                <StackPanel Grid.Row="0" Margin="0,24,0,20">
                    <StackPanel Orientation="Horizontal"
                                Margin="24,0,0,20">
                        <Border Background="#6C63FF" CornerRadius="10"
                                Width="36" Height="36" Margin="0,0,10,0">
                            <TextBlock Text="✓" FontSize="18"
                                       FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="TaskFlow" FontSize="18"
                                   FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Background="#16213E" CornerRadius="12"
                            Margin="12,0" Padding="12,10">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#6C63FF" CornerRadius="50"
                                    Width="36" Height="36" Margin="0,0,10,0">
                                <TextBlock x:Name="txtAvatarInitial"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="txtSidebarName"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock x:Name="txtSidebarRole"
                                           FontSize="11" Foreground="#6C63FF"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Nav -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <TextBlock Text="MENU" Foreground="#3A3A5C"
                               FontSize="10" FontWeight="Bold"
                               Margin="24,0,0,8"/>

                    <Button Style="{StaticResource SidebarButton}"
                            Click="btnNavDashboard_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButtonActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Projects" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButton}"
                            Click="btnNavTasks_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✅" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Tasks" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnNavActivity"
                            Style="{StaticResource SidebarButton}"
                            Click="btnNavActivity_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Activity Log" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Logout -->
                <StackPanel Grid.Row="2" Margin="0,0,0,20">
                    <Separator Background="#1A1A2E" Margin="16,0,16,12"/>
                    <Button Style="{StaticResource SidebarButton}"
                            Click="btnLogout_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Logout" Foreground="#FF6584"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ MAIN CONTENT ══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#0F0E17"
                    Padding="32,24,32,16">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Projects"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock x:Name="txtProjectCount"
                                   FontSize="13" Foreground="#A7A9BE"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button x:Name="btnNewProject"
                            Content="+ New Project"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Height="40" Padding="20,0"
                            FontSize="13" FontWeight="SemiBold"
                            Foreground="White" Background="#6C63FF"
                            BorderThickness="0" Cursor="Hand"
                            Click="btnNewProject_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg"
                                                Property="Background" Value="#5A52E0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition x:Name="colForm" Width="0"/>
                </Grid.ColumnDefinitions>

                <!-- Projects List -->
                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              Padding="32,0,32,32"
                              Margin="0,8,0,0">
                    <StackPanel>

                        <!-- Empty State -->
                        <Border x:Name="emptyState"
                                Visibility="Collapsed"
                                Padding="0,60">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="📁" FontSize="48"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="No projects yet"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,6"/>
                                <TextBlock Text="Click '+ New Project' to create your first project"
                                           FontSize="13" Foreground="#A7A9BE"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Projects Grid -->
                        <ItemsControl x:Name="lstProjects">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#16213E"
                                            CornerRadius="16"
                                            Padding="22,20"
                                            Margin="0,0,16,16"
                                            Width="290">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                             Value="True">
                                                        <Setter Property="Background"
                                                                Value="#1E2A4E"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>

                                            <!-- Icon & Name -->
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,0,0,12">
                                                <Border Background="#1A1A5E"
                                                        CornerRadius="10"
                                                        Width="42" Height="42"
                                                        Margin="0,0,12,0">
                                                    <TextBlock Text="📁" FontSize="20"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ProjectName}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="180"/>
                                                    <TextBlock Text="{Binding CreatedDate}"
                                                               FontSize="11"
                                                               Foreground="#6C63FF"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Description -->
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="12"
                                                       Foreground="#A7A9BE"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="48"
                                                       Margin="0,0,0,14"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <!-- Stats Row -->
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,0,0,14">
                                                <Border Background="#0F0E17"
                                                        CornerRadius="6"
                                                        Padding="8,4"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Foreground="#A7A9BE"
                                                               FontSize="11">
                                                        <Run Text="✅ "/>
                                                        <Run Text="{Binding TaskCount}"/>
                                                        <Run Text=" tasks"/>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>

                                            <!-- Action Buttons -->
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="✏ Edit"
                                                        Tag="{Binding ProjectID}"
                                                        Height="32" Padding="14,0"
                                                        FontSize="12"
                                                        Foreground="#6C63FF"
                                                        Background="#1A1A5E"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Margin="0,0,8,0"
                                                        Click="btnEdit_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bg"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="8">
                                                                <ContentPresenter
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Margin="{TemplateBinding Padding}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver"
                                                                         Value="True">
                                                                    <Setter TargetName="bg"
                                                                            Property="Background"
                                                                            Value="#252570"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <Button Content="🗑 Delete"
                                                        Tag="{Binding ProjectID}"
                                                        Height="32" Padding="14,0"
                                                        FontSize="12"
                                                        Foreground="#FF6584"
                                                        Background="#2A1020"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Click="btnDelete_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bg"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="8">
                                                                <ContentPresenter
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Margin="{TemplateBinding Padding}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver"
                                                                         Value="True">
                                                                    <Setter TargetName="bg"
                                                                            Property="Background"
                                                                            Value="#3A1530"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>

                <!-- ══ SLIDE-IN FORM PANEL ══ -->
                <Border x:Name="formPanel"
                        Grid.Column="1"
                        Background="#0A0A14"
                        BorderBrush="#1A1A2E"
                        BorderThickness="1,0,0,0"
                        Padding="28,24">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <TextBlock x:Name="txtFormTitle"
                                       Text="New Project"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,24"/>

                            <!-- Project Name -->
                            <TextBlock Text="PROJECT NAME"
                                       Foreground="#A7A9BE" FontSize="11"
                                       FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBox x:Name="txtProjectName"
                                     Style="{StaticResource FormInput}"
                                     Margin="0,0,0,4"/>
                            <TextBlock x:Name="errProjectName"
                                       Foreground="#FF6584" FontSize="11"
                                       Visibility="Collapsed"
                                       Margin="0,0,0,12"/>

                            <!-- Description -->
                            <TextBlock Text="DESCRIPTION"
                                       Foreground="#A7A9BE" FontSize="11"
                                       FontWeight="Bold" Margin="0,16,0,6"/>
                            <TextBox x:Name="txtDescription"
                                     Style="{StaticResource FormTextArea}"
                                     Margin="0,0,0,4"/>

                            <!-- Error Banner -->
                            <Border x:Name="borderError"
                                    Background="#2A1020"
                                    BorderBrush="#FF6584"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,8,0,0"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="txtError"
                                           Foreground="#FF6584"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <!-- Buttons -->
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,24,0,0">

                                <Button x:Name="btnSave"
                                        Content="Save Project"
                                        Height="40" Padding="20,0"
                                        FontSize="13" FontWeight="SemiBold"
                                        Foreground="White"
                                        Background="#6C63FF"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Margin="0,0,10,0"
                                        Click="btnSave_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="10">
                                                <ContentPresenter
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                    <Setter TargetName="bg"
                                                            Property="Background"
                                                            Value="#5A52E0"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled"
                                                         Value="False">
                                                    <Setter TargetName="bg"
                                                            Property="Background"
                                                            Value="#3A3A5C"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button Content="Cancel"
                                        Height="40" Padding="20,0"
                                        FontSize="13"
                                        Foreground="#A7A9BE"
                                        Background="#1E1E3F"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="btnCancel_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="10">
                                                <ContentPresenter
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                    <Setter TargetName="bg"
                                                            Property="Background"
                                                            Value="#2A2A5A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

            </Grid>
        </Grid>

    </Grid>
</Window>