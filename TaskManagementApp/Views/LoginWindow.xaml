<Window x:Class="TaskManagementApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskFlow — Login"
        Height="600" Width="900"
        WindowState="Maximized"
        ResizeMode="CanResize"
        MinHeight="500" MinWidth="700"
        Background="#0F0E17">

    <Window.Resources>

        <!-- INPUT FIELD STYLE -->
        <Style x:Key="LoginInputField" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1E1E3F"/>
            <Setter Property="CaretBrush" Value="#6C63FF"/>
            <Setter Property="SelectionBrush" Value="#6C63FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border"
                                        Property="BorderBrush" Value="#6C63FF"/>
                                <Setter TargetName="border"
                                        Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="BorderBrush" Value="#4A4A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PASSWORD FIELD STYLE -->
        <Style x:Key="LoginPasswordField" TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1E1E3F"/>
            <Setter Property="CaretBrush" Value="#6C63FF"/>
            <Setter Property="SelectionBrush" Value="#6C63FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border"
                                        Property="BorderBrush" Value="#6C63FF"/>
                                <Setter TargetName="border"
                                        Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="BorderBrush" Value="#4A4A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- LABEL STYLE -->
        <Style x:Key="LoginLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A7A9BE"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- ERROR TEXT STYLE -->
        <Style x:Key="LoginErrorText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF6584"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="2,4,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ LEFT PANEL ══ -->
        <Border Grid.Column="0" Background="#6C63FF">
            <Grid>
                <!-- Decorative circles -->
                <Ellipse Width="300" Height="300"
                         Fill="#5A52E0" Opacity="0.4"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Top"
                         Margin="-100,-100,0,0"/>
                <Ellipse Width="200" Height="200"
                         Fill="#7C73FF" Opacity="0.3"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Bottom"
                         Margin="0,0,-50,-50"/>

                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="40">

                    <!-- Logo -->
                    <Border Background="White" CornerRadius="16"
                            Width="70" Height="70"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000"
                                             BlurRadius="15"
                                             ShadowDepth="2"
                                             Opacity="0.2"/>
                        </Border.Effect>
                        <TextBlock Text="✓" FontSize="34"
                                   Foreground="#6C63FF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                    </Border>

                    <TextBlock Text="TaskFlow"
                               FontSize="36" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Manage your projects smarter"
                               FontSize="14"
                               Foreground="#D4D0FF"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,40"/>

                    <!-- Feature List -->
                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,14">
                            <Border Background="White" CornerRadius="50"
                                    Width="26" Height="26"
                                    Margin="0,0,12,0">
                                <TextBlock Text="✓" FontSize="13"
                                           Foreground="#6C63FF"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="Track projects and tasks"
                                       Foreground="White" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,14">
                            <Border Background="White" CornerRadius="50"
                                    Width="26" Height="26"
                                    Margin="0,0,12,0">
                                <TextBlock Text="✓" FontSize="13"
                                           Foreground="#6C63FF"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="Collaborate with your team"
                                       Foreground="White" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Border Background="White" CornerRadius="50"
                                    Width="26" Height="26"
                                    Margin="0,0,12,0">
                                <TextBlock Text="✓" FontSize="13"
                                           Foreground="#6C63FF"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="Real-time progress reports"
                                       Foreground="White" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ RIGHT PANEL ══ -->
        <Border Grid.Column="1" Background="#0F0E17">
            <ScrollViewer VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel VerticalAlignment="Center"
                            Margin="50,30">

                    <TextBlock Text="Welcome back"
                               FontSize="28" FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="Sign in to your account"
                               FontSize="13" Foreground="#A7A9BE"
                               Margin="0,0,0,35"/>

                    <!-- ── Email ── -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="EMAIL ADDRESS"
                                   Style="{StaticResource LoginLabel}"/>
                        <TextBox x:Name="txtEmail"
                                 Style="{StaticResource LoginInputField}"
                                 TextChanged="txtEmail_TextChanged"/>
                        <TextBlock x:Name="errEmail"
                                   Style="{StaticResource LoginErrorText}"/>
                    </StackPanel>

                    <!-- ── Password ── -->
                    <StackPanel Margin="0,0,0,5">
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="PASSWORD"
                   Style="{StaticResource LoginLabel}"
                   Margin="0"/>
                            <TextBlock Text="Forgot password?"
                   Foreground="#6C63FF"
                   FontSize="11"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   Cursor="Hand"/>
                        </Grid>
                        <Grid>
                            <PasswordBox x:Name="txtPassword"
                     Style="{StaticResource LoginPasswordField}"
                     Padding="12,0,45,0"
                     PasswordChanged="txtPassword_PasswordChanged"/>
                            <TextBox x:Name="txtPasswordVisible"
                 Height="42"
                 FontSize="13"
                 Foreground="White"
                 Background="#1E1E3F"
                 CaretBrush="#6C63FF"
                 SelectionBrush="#6C63FF"
                 BorderThickness="1"
                 BorderBrush="#2A2A4A"
                 Padding="12,0,45,0"
                 VerticalContentAlignment="Center"
                 Cursor="IBeam"
                 Visibility="Collapsed">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter TargetName="border"
                                    Property="BorderBrush" Value="#6C63FF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>

                            <!-- Eye Button -->
                            <Button x:Name="btnTogglePassword"
                Content="👁"
                Width="36" Height="36"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,6,0"
                Cursor="Hand"
                Click="btnTogglePassword_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                        <TextBlock x:Name="errPassword"
               Style="{StaticResource LoginErrorText}"/>
                    </StackPanel>

                    <!-- ── General Error ── -->
                    <Border x:Name="borderError"
                            Background="#2A1020"
                            BorderBrush="#FF6584"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,10"
                            Margin="0,15,0,0"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠  "
                                       Foreground="#FF6584"
                                       FontSize="13"/>
                            <TextBlock x:Name="txtError"
                                       Foreground="#FF6584"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Login Button ── -->
                    <Button x:Name="btnLogin"
                            Content="Sign In"
                            Height="46"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Background="#6C63FF"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,25,0,0"
                            Click="btnLogin_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder"
                                                Property="Background"
                                                Value="#5A52E0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="btnBorder"
                                                Property="Background"
                                                Value="#4A42D0"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="btnBorder"
                                                Property="Background"
                                                Value="#3A3A5C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- ── Divider ── -->
                    <Grid Margin="0,22,0,22">
                        <Separator Background="#2A2A4A"/>
                        <Border Background="#0F0E17"
                                HorizontalAlignment="Center"
                                Padding="12,0">
                            <TextBlock Text="or"
                                       Foreground="#A7A9BE"
                                       FontSize="12"/>
                        </Border>
                    </Grid>

                    <!-- ── Register Link ── -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Don't have an account?  "
                                   Foreground="#A7A9BE" FontSize="13"/>
                        <TextBlock x:Name="lnkRegister"
                                   Text="Create one"
                                   Foreground="#6C63FF"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Cursor="Hand"
                                   MouseLeftButtonDown="Register_Click">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="TextDecorations"
                                                    Value="Underline"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Version -->
                    <TextBlock Text="TaskFlow v1.0"
                               Foreground="#3A3A5C"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,25,0,10"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</Window>